# Generic Nginx template for Activity-Relay plus the generated landing site.
#
# build-site.py must use the same output directory configured by the root
# directive below. With the example paths, build the site using:
#
#   python3 /etc/activity-relay-web/build-site.py \
#     --source /etc/activity-relay-web \
#     --config /etc/activity-relay-web/site.json \
#     --output /var/www/activity-relay/public
#
# Nginx serves those generated files. The landing-page JavaScript requests
# /status.json, which Nginx proxies to the Go relay backend.
#
# Replace relay.example.org, certificate paths, log paths, root, and backend
# address as needed.

upstream activity_relay_backend {
    server 127.0.0.1:8080;
    keepalive 16;
}

# Per-source admission controls. Put these in the http context if this file is
# included from inside a server block on your distribution.
limit_req_zone $binary_remote_addr zone=relay_inbox_rate:10m rate=30r/s;
limit_conn_zone $binary_remote_addr zone=relay_per_source:10m;

server {
    listen 80;
    listen [::]:80;
    server_name relay.example.org;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    listen [::]:443 ssl;
    http2 on;

    server_name relay.example.org;

    ssl_certificate     /etc/letsencrypt/live/relay.example.org/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/relay.example.org/privkey.pem;

    # Optional local hardening include:
    # include /etc/nginx/snippets/block-sensitive-probes.conf;

    # This must match build-site.py --output.
    root /var/www/activity-relay/public;
    index index.html;

    client_max_body_size 1M;

    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "same-origin" always;
    add_header X-Frame-Options "DENY" always;
    add_header Content-Security-Policy "default-src 'self'; img-src 'self' data: https:; style-src 'self'; script-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'none'; form-action 'self'" always;

    location = /inbox {
        limit_req zone=relay_inbox_rate burst=60 nodelay;
        limit_conn relay_per_source 20;
        limit_req_status 429;
        limit_conn_status 429;
        proxy_pass http://activity_relay_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_request_buffering off;
        proxy_buffering off;
    }

    location = /actor {
        proxy_pass http://activity_relay_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Live dashboard data from the Go relay. This exact match takes
    # precedence over the static location / block below.
    location = /status.json {
        proxy_pass http://activity_relay_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /.well-known/nodeinfo {
        proxy_pass http://activity_relay_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /.well-known/webfinger {
        proxy_pass http://activity_relay_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /nodeinfo/2.1 {
        proxy_pass http://activity_relay_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /assets/ {
        try_files $uri =404;
        expires 1h;
        add_header Cache-Control "public, max-age=3600";
    }

    # Generated landing page and content pages.
    location / {
        try_files $uri $uri/ =404;
    }

    access_log /var/log/nginx/activity-relay.access.log combined;
    error_log  /var/log/nginx/activity-relay.error.log warn;
}
