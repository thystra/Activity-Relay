# Single-disk VPS defaults.
RELAY_STORAGE_DIR=/var/lib/activity-relay/redis
RELAY_CACHE_DIR=/var/cache/activity-relay

# Optional split-storage example: put durable Redis data on another mounted
# filesystem while leaving transient cache on the local disk.
# RELAY_STORAGE_DIR=/mnt/activity-relay-nas/redis
# RELAY_CACHE_DIR=/var/cache/activity-relay

# Redis uses noeviction: writes fail safely instead of deleting relay metadata.
REDIS_MAXMEMORY=512mb
REDIS_CONTAINER_MEMORY=768m
SERVER_MEMORY_LIMIT=512m
WORKER_MEMORY_LIMIT=512m

# Per-container bounded local logs (approximately size x files).
CONTAINER_LOG_MAX_SIZE=10m
CONTAINER_LOG_MAX_FILES=5
